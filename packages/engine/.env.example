# ═══════════════════════════════════════════════════════
#  Orbinex Engine — environment variables
#  Copy to .env and choose ONE provider block below.
# ═══════════════════════════════════════════════════════

PORT=3001
NODE_ENV=development

# ════════════════════════════════════════════════════════
#  LLM PROVIDER — uncomment the one you want to use
# ════════════════════════════════════════════════════════

# ── OPTION 1: Ollama (FREE — no API key, runs locally) ──
# Install: https://ollama.com  then run: ollama pull llama3.1
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5
LLM_BASE_URL=http://localhost:11434
# LLM_API_KEY=    ← leave blank, Ollama doesn't need a key

# ── OPTION 2: Anthropic Claude ──────────────────────────
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=    ← leave blank

# ── OPTION 3: OpenAI ────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...
# LLM_BASE_URL=    ← leave blank

# ── OPTION 4: Google Gemini (OpenAI-compat) ─────────────
# LLM_PROVIDER=google
# LLM_MODEL=gemini-1.5-flash
# LLM_API_KEY=AIza...
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ════════════════════════════════════════════════════════
#  Generation settings
# ════════════════════════════════════════════════════════
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7
MAX_HISTORY=20

# ════════════════════════════════════════════════════════
#  MCP Server connection
# ════════════════════════════════════════════════════════
MCP_SERVER_URL=http://localhost:3002
MCP_API_KEY=dev-mcp-key

# ════════════════════════════════════════════════════════
#  System prompt (optional — customize AI personality)
# ════════════════════════════════════════════════════════
# SYSTEM_PROMPT=You are a helpful assistant for Acme Corp. Be concise and friendly.

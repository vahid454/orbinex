# ═══════════════════════════════════════════════════════
#  Orbinex MCP Server — environment variables
#  Copy to .env and fill in your values.
# ═══════════════════════════════════════════════════════

PORT=3002
MCP_API_KEY=dev-mcp-key

# ── LLM (for RAG tool) ───────────────────────────────────────────────
# Ollama is free — install from https://ollama.com, then:
#   ollama pull llama3
#   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# ── Weather tool ─────────────────────────────────────────────────────
WEATHER_ENABLED=true
# Optional: free key from https://openweathermap.org/api
# Without it, falls back to open-meteo.com (also free, no key needed)
OPENWEATHER_API_KEY=
WEATHER_UNITS=metric
WEATHER_DEFAULT_CITY=Mumbai

# ── RAG document search ───────────────────────────────────────────────
RAG_ENABLED=true
RAG_DOCS_PATH=./data/docs
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_GENERATION_MODEL=llama3
RAG_TOP_K=4
RAG_INDEX_PATH=./data/rag-index.json

# ── City Tour tool ────────────────────────────────────────────────────
CITY_TOUR_ENABLED=true

# ── Country Info tool ─────────────────────────────────────────────────
COUNTRY_INFO_ENABLED=true

# ── Currency Exchange tool ────────────────────────────────────────────
CURRENCY_ENABLED=true

# ── Experience API tool (your real API) ───────────────────────────────
EXPERIENCE_API_ENABLED=true
# Change this to your actual endpoint URL
EXPERIENCE_API_URL=http://localhost:5017/Experience
# Optional: Bearer token if your API requires authentication
EXPERIENCE_API_KEY=

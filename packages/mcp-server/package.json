{
  "name": "@orbinex/mcp-server",
  "version": "0.1.0",
  "description": "Drop-in MCP server for Orbinex — add your own tools and connect to Orbinex Engine",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "orbinex-mcp": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@orbinex/shared": "*",
    "dotenv": "^16.4.0",
    "fastify": "^4.27.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.10.0",
    "typescript": "^5.4.0"
  }
}
